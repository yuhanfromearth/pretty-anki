{
  "name": "pretty-anki",
  "version": "0.0.0-development",
  "description": "Web UI for Anki running locally.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "bin": {
    "nts": "bin/nts.mjs"
  },
  "files": [
    "bin",
    "apps/be/dist",
    "apps/be/package.json",
    "apps/ui/dist/client"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=shared",
    "build": "npm run build:shared && npm run build --workspace=apps/be && npm run build --workspace=apps/ui",
    "start": "npm run build:shared && concurrently -n shared,be,ui -c yellow,blue,magenta \"npm run dev --workspace=shared\" \"npm run start:dev --workspace=apps/be\" \"npm run dev --workspace=apps/ui\"",
    "start:prod": "npm run build && node bin/nts.mjs",
    "prepack": "npm run build && node scripts/prepack.mjs",
    "postpack": "node scripts/postpack.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@nts/shared": "0.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "nestjs-zod": "^5.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.0.0"
  },
  "bundleDependencies": [
    "@nts/shared"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
